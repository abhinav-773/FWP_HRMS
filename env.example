# ==========================================
# HRGPT Production Environment Variables
# ==========================================

# -----------------
# Core Settings
# -----------------
NODE_ENV=production
PORT=5000

# -----------------
# Databases
# -----------------
# PostgreSQL (Prisma)
DATABASE_URL=postgresql://admin:password@postgres:5432/hrgpt_db?schema=public

# MongoDB (Mongoose)
MONGODB_URI=mongodb://admin:password@mongodb:27017/hrgpt_chat?authSource=admin

# Redis (Caching & PubSub)
REDIS_URL=redis://redis:6379

# -----------------
# Security
# -----------------
# Generate secure random strings (e.g., `openssl rand -hex 64`)
JWT_SECRET=replace_this_with_a_highly_secure_random_string_for_production
JWT_REFRESH_SECRET=replace_this_with_another_highly_secure_random_string_for_production

# -----------------
# AI Service Connectors
# -----------------
# Fast API Service URL (Called by Backend)
AI_SERVICE_URL=http://ai-service:8000

# Ollama Instance URL (Called by AI Service)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# -----------------
# Frontend Configuration (Vite)
# -----------------
# Placed in frontend/.env
VITE_API_URL=https://app.hrgpt.com/api/v1
VITE_SOCKET_URL=https://app.hrgpt.com
